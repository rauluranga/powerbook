#!/usr/bin/env bash

# Install command-line tools using Homebrew
run_brew() {
	
	# Make sure we’re using the latest Homebrew
	brew update

	# Upgrade any already-installed formulae
	brew upgrade

	brew tap thoughtbot/formulae
	brew install gitsh

    brew install bat
    brew install git
	brew install git-flow
	brew install git-extras
    brew install git-delta
	brew install hub
	brew install the_silver_searcher
	brew install tig
	brew install tmux
	brew install rename
	brew install reattach-to-user-namespace
	brew install tree
	brew install cowsay
	brew install fortune
	brew install figlet
	brew install toilet
    brew install starship
    brew install nvim
    brew install zoxide
    brew install fzf
	
	# pyenv 
	brew install pyenv
    brew install pipenv

	# rbenv 
	brew install rbenv

	# Remove outdated versions from the cellar
	brew cleanup
}
